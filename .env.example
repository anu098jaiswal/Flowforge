# Copy this to .env (or export these in your shell) before running the app.
# Never commit real values.

DB_URL=jdbc:postgresql://localhost:5432/flowforge
DB_USERNAME=postgres
DB_PASSWORD=your_postgres_password

# Gmail: use an "app password" (Google Account > Security > 2-Step Verification
# > App passwords), not your normal login password.
MAIL_USERNAME=you@gmail.com
MAIL_PASSWORD=your_16_char_app_password

# Set to true to enable the inbox poller that drives EMAIL-trigger workflows
EMAIL_POLL_ENABLED=false
EMAIL_POLL_INTERVAL_MS=30000

# Use a long, random, secret value in production (this is what signs JWTs).
JWT_SECRET=change-this-to-a-long-random-string-before-deploying
JWT_EXPIRATION=86400000

# Comma-separated list of frontend origins allowed to call the API.
# Add your deployed frontend URL here.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
